DATABASE_URL=postgresql://minicrm:minicrm_secret@db:5432/minicrm
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
# После смены пароля в .env включите на один перезапуск backend, иначе в БД останется старый хеш:
# ADMIN_SYNC_PASSWORD_FROM_ENV=true
ADMIN_SYNC_PASSWORD_FROM_ENV=false
DEBUG_MODE=false
CORS_ORIGINS=*
# Set to false for local HTTP development, true for production HTTPS
COOKIE_SECURE=false
